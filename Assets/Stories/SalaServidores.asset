  - guid: 35672bb8-60b8-4aa2-9b55-4546f8b34031
    characterSpr: {fileID: 21300000, guid: 7f01622113486ae4d9c587e6a83f0445, type: 3}
    characterName: Nova Chefe(?)
    dialogueText: "Ah, o Chester vai ser o antigo chefe um dia\u2026 tudo que \xE9
