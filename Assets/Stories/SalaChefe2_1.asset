  - guid: e0529b28-2c0f-4ba0-a98c-259949366f3a
    characterSpr: {fileID: 21300000, guid: 9c983164e6fa82948968e14cd1200977, type: 3}
    characterName: "Voc\xEA"
    dialogueText: "N\xE3o sei se ela vai me deixar fazer isso, senhor."
    backgroundSpr: {fileID: 21300000, guid: 3ca3deff72af3854d882fcf4f1c66d37, type: 3}
    startNode: 0
    endNode: 0
