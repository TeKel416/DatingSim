      width: 499
      height: 371
    soundEffect: {fileID: 0}
    backgroundMusic: {fileID: 0}
    likeGain: 0
    showLikeBar: 0
  - guid: 69241ade-a59e-4976-bf90-4bca0454ee6e
    characterSpr: {fileID: 21300000, guid: 9c983164e6fa82948968e14cd1200977, type: 3}
    characterName: Chester
    dialogueText: "O que fazemos? Ora bolas, ganhamos dinheiro! Isso a\xED deve dar
      bastante, aprenda a mexer nessa coisa e fa\xE7a ela realizar tarefas."
    backgroundSpr: {fileID: 21300000, guid: 3ca3deff72af3854d882fcf4f1c66d37, type: 3}
    startNode: 0
    endNode: 0
    choices: 1
    choiceOptions:
    - 
    nodePosition:
      serializedVersion: 2
      x: 5504
      y: -154
      width: 499
      height: 371
    soundEffect: {fileID: 0}
    backgroundMusic: {fileID: 0}
    likeGain: 0
    showLikeBar: 0
  - guid: a3870e1d-cb21-46b9-9e13-13f81fa2dea0
    characterSpr: {fileID: 21300000, guid: 9c983164e6fa82948968e14cd1200977, type: 3}
    characterName: Chester
    dialogueText: "Sim, consigo ver aqui\u2026 Isso deve dar um dinheiro e tanto.
      Veja o que ela pode fazer e me informe."
    backgroundSpr: {fileID: 21300000, guid: 3ca3deff72af3854d882fcf4f1c66d37, type: 3}
    startNode: 0
    endNode: 0
    choices: 1
    choiceOptions:
