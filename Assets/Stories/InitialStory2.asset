      y: 104
      width: 499
      height: 305
    soundEffect: {fileID: 0}
    backgroundMusic: {fileID: 0}
  - guid: b6d56dbb-664a-4498-80e7-d929ce1fdd04
    characterSpr: {fileID: 21300000, guid: 9c3a05b2ac701a24ab670be6be22e5ef, type: 3}
    characterName: "Voc\xEA"
    dialogueText: "N\xE3o quero passar a madrugada aqui, acho que vou fazer outra
      coisa e deixar esses pap\xE9is pra outro dia."
    backgroundSpr: {fileID: 21300000, guid: 9c3a05b2ac701a24ab670be6be22e5ef, type: 3}
    startNode: 0
    endNode: 0
    choices: 1
    choiceOptions:
    - 
    nodePosition:
      serializedVersion: 2
      x: 1825
      y: 99
      width: 499
      height: 305
    soundEffect: {fileID: 0}
    backgroundMusic: {fileID: 0}
  - guid: 7d084069-7442-48d2-8f23-1e401b13103d
    characterSpr: {fileID: 21300000, guid: 9c3a05b2ac701a24ab670be6be22e5ef, type: 3}
    characterName: "Voc\xEA"
    dialogueText: "Tinha um documento do chefe pra entregar pro Figgs, se n\xE3o
      me engano era o de presta\xE7\xE3o de contas. Acho que vou procurar por ele
      para me ocupar."
    backgroundSpr: {fileID: 21300000, guid: 9c3a05b2ac701a24ab670be6be22e5ef, type: 3}
    startNode: 0
    endNode: 1
    choices: 1
    choiceOptions:
    - 
    nodePosition:
      serializedVersion: 2
      x: 2358
      y: 93
      width: 499
      height: 305
    soundEffect: {fileID: 0}
    backgroundMusic: {fileID: 0}
  - guid: 909d0dda-20ca-4609-840d-10bde64799f2
