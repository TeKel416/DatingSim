  - guid: 5a3291c5-95f0-4678-996d-9e0245c9636f
    characterSpr: {fileID: 21300000, guid: 9c3a05b2ac701a24ab670be6be22e5ef, type: 3}
    characterName: "Voc\xEA"
    dialogueText: "Essa mudan\xE7a e conex\xE3o para os sat\xE9lites est\xE3o ferrando
