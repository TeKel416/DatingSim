  - guid: 657de0e3-9b50-4192-bd85-6c76b71be786
    characterSpr: {fileID: 0}
    characterName: Chefe
    dialogueText: "\xC9 bom que esteja mesmo, porque  sen\xE3o eu vou come\xE7ar
