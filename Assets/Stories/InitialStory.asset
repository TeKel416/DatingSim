  - guid: dd012154-72d5-443f-bd3c-7c30da2a0fa3
    characterSpr: {fileID: 0}
    characterName: "Voc\xEA"
    dialogueText: "Sigh... Finalmente ele desligou. Esses \xFAltimos dias t\xEAm
      sido muito pesados. \xC9 a primeira vez nessa semana que vou dormir na minha
      cama ao inv\xE9s do escrit\xF3rio."
