  - guid: 4af2c7d7-5beb-451c-bc3e-95f8dad56023
    characterSpr: {fileID: 0}
    characterName: Chefe
    dialogueText: "Estou ligando porque todos do time estar\xE3o l\xE1. \xC9 a primeira
      vez que os sat\xE9lites v\xE3o entrar em funcionamento e precisamos ter certeza
      que TODOS os envolvidos estejam dispon\xEDveis caso algum imprevisto aconte\xE7a."
    backgroundSpr: {fileID: 21300000, guid: ba8a446527e5e9643827dd5d41b67ddd, type: 3}
